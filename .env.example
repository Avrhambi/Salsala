# ──────────────────────────────────────────────
# Salsala — Environment Variable Template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# Database (PostgreSQL + PostGIS)
DATABASE_URL=

# Application secret key (JWT signing, session tokens)
APP_SECRET_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# File / image storage base path
STORAGE_BASE_PATH=/storage

# OCR service (if using a cloud provider)
OCR_API_KEY=

# NLP model path (optional override; defaults to bundled spaCy model)
NLP_MODEL_PATH=
